{
  "name": "arcane-ledger-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "generate": "prisma generate",
    "test": "DATABASE_URL=postgresql://arcane:arcane_dev_pass@localhost:5432/arcane_ledger_test vitest run",
    "test:watch": "DATABASE_URL=postgresql://arcane:arcane_dev_pass@localhost:5432/arcane_ledger_test vitest",
    "test:setup-db": "docker exec -i $(docker ps -qf name=postgres) psql -U arcane -d postgres -c \"CREATE DATABASE arcane_ledger_test\" 2>/dev/null; DATABASE_URL=postgresql://arcane:arcane_dev_pass@localhost:5432/arcane_ledger_test npx prisma db push && DATABASE_URL=postgresql://arcane:arcane_dev_pass@localhost:5432/arcane_ledger_test npx tsx src/seed.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@graphql-tools/schema": "^10.0.31",
    "@prisma/client": "^6.4.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "graphql": "^16.9.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^5.16.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.13",
    "prisma": "^6.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.2"
  }
}
